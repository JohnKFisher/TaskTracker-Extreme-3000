{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TaskTracker Extreme 3000",
  "version": "2.0.0",
  "identifier": "com.tasktracker.extreme3000",
  "build": {
    "frontendDist": "../renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TaskTracker Extreme 3000",
        "width": 380,
        "height": 800,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": false,
        "minWidth": 300,
        "maxWidth": 600,
        "url": "index.html",
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "entitlements": null
    }
  }
}
