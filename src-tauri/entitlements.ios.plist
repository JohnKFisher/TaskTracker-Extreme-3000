<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- iOS Keychain access for Desk365 API key storage (used by the keyring crate) -->
  <key>keychain-access-groups</key>
  <array>
    <string>$(AppIdentifierPrefix)com.tasktracker.extreme3000</string>
  </array>
  <!-- Read/write access to user-selected folders (iCloud Drive sync folder via Files picker) -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
