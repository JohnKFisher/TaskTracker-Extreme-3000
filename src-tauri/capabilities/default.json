{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default local-window capabilities for TaskTracker Extreme 3000",
  "windows": ["main", "quick-add"],
  "platforms": ["macOS", "windows"],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:webview:default",
    "core:window:default",
    "core:window:allow-start-dragging"
  ]
}
